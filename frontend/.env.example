# frontend/.env.example
# Copia este archivo como .env para desarrollo local.
# En producción esta variable va vacía (el build de Vite la deja en "")
# y CloudFront enruta /api/* al ALB automáticamente.

# Desarrollo local: apunta al backend local
VITE_API_BASE_URL=http://localhost:5000

# Producción: dejar vacío (sin comillas, sin espacios)
# VITE_API_BASE_URL=
